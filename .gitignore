# Root-level .gitignore for Affiliate Benchmarking Project

# ─── Secrets & API Credentials ──────────────────────────────────────────────
.env
.env.local
.env.*.local
firebase-admin-sdk.json

# ─── Python Dependencies & Cache ──────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
pip-log.txt
pip-delete-this-directory.txt
.venv/
.env/

# ─── Node / Next.js Directories ────────────────────────────────────────────────
node_modules/
.next/
out/
build/
.vercel/

# ─── OS Files ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─── Log Files ────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
